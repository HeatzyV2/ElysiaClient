# Source files and config should stay LF
*.java text eol=lf
*.json text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.svg text eol=lf
*.sh text eol=lf

# Windows scripts should stay CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary assets
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.jar binary
*.exe binary
*.blockmap binary
